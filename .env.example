# ─── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_USER=usina
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA_FORTE
POSTGRES_DB=usina_erp

# ─── Segurança ─────────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 64
JWT_SECRET=GERE_UMA_CHAVE_FORTE_AQUI
JWT_EXPIRES_IN=8h

# ─── Servidor ──────────────────────────────────────────────────────────────────
NODE_ENV=production
FRONTEND_URL=http://SEU_IP_OU_DOMINIO

# ─── Integrações de hardware (deixe em branco para modo simulação) ─────────────
# IP/hostname da balança rodoviária (serial via TCP)
SCALE_HOST=
SCALE_PORT=4001

# IP/hostname do controlador MX3000 da usina
MX3000_HOST=
MX3000_PORT=4002
