# ─── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_USER=usina
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA
POSTGRES_DB=usina_erp

# URL completa usada pelo Prisma (gerada automaticamente no Docker)
DATABASE_URL=postgresql://usina:TROQUE_ESTA_SENHA@localhost:5432/usina_erp

# ─── Segurança ─────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 48
JWT_SECRET=GERE_UMA_CHAVE_FORTE_AQUI
JWT_EXPIRES_IN=8h

# ─── Servidor ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=http://localhost

# ─── Integrações de hardware ──────────────────────────────────────────────────
# IP/hostname da balança rodoviária (serial via TCP)
SCALE_HOST=192.168.1.100
SCALE_PORT=4001

# IP/hostname do controlador MX3000 da usina
MX3000_HOST=192.168.1.101
MX3000_PORT=4002
